---
interface Props {
  variant?: "feature" | "page";
  image?: string;
  imageAlt?: string;
}
const { variant = "feature", image, imageAlt = "" } = Astro.props;
const hasImage = Boolean(image) && variant === "feature";
const heroClass =
  variant === "page"
    ? "page-hero page-hero--light"
    : hasImage
    ? "page-hero"
    : "page-hero page-hero--no-image";
---
<section class={heroClass}>
  {hasImage && (
    <img class="page-hero__bg" src={image} alt={imageAlt} width="1920" height="1080" loading="eager" fetchpriority="high" aria-hidden={imageAlt ? undefined : "true"} />
  )}
  <div class="container">
    {Astro.slots.has("eyebrow") && <span class="eyebrow"><slot name="eyebrow" /></span>}
    <h1><slot name="title" /></h1>
    {Astro.slots.has("lede") && <p class="lede"><slot name="lede" /></p>}
  </div>
</section>

<style is:global>
  .page-hero{
    position:relative;min-height:var(--hero-min-h);
    display:flex;align-items:flex-end;
    padding:96px 0 72px;
    overflow:hidden;isolation:isolate;
    background:var(--petrol-dark);color:var(--creme);
  }
  .page-hero::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background-image:linear-gradient(135deg,var(--petrol-dark) 0%, var(--petrol) 55%, #156063 100%);
    background-size:cover;background-position:center;
  }
  .page-hero::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background:linear-gradient(180deg, rgba(10,54,56,0.25) 0%, rgba(10,54,56,0.72) 100%);
  }
  .page-hero.page-hero--no-image::after{background:linear-gradient(180deg, rgba(10,54,56,0) 0%, rgba(10,54,56,0.25) 100%);}
  .page-hero__bg{position:absolute;inset:0;z-index:-2;width:100%;height:100%;object-fit:cover;}
  .page-hero .container{position:relative;width:100%;}
  .page-hero .eyebrow{color:var(--gold);margin-bottom:18px;display:block;}
  .page-hero h1{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(42px, 5.4vw, 76px);line-height:1.04;letter-spacing:-0.02em;
    color:var(--creme);text-wrap:balance;margin:0 0 22px;max-width:22ch;
  }
  .page-hero h1 em{font-style:italic;color:var(--gold);}
  .page-hero .lede{
    font-family:var(--sans);font-size:19px;line-height:1.55;
    color:rgba(245,239,231,0.9);max-width:720px;margin:0;text-wrap:pretty;
  }

  .page-hero--light{
    background:var(--creme);color:var(--tinte);
    min-height:auto;padding:96px 0 64px;align-items:flex-start;
    border-bottom:1px solid var(--hairline);
  }
  .page-hero--light::before{
    background-image:
      radial-gradient(ellipse at 15% 10%, rgba(127,176,105,0.10), transparent 45%),
      radial-gradient(ellipse at 85% 90%, rgba(212,165,116,0.10), transparent 50%),
      var(--creme);
  }
  .page-hero--light::after{display:none;}
  .page-hero--light .eyebrow{color:var(--bordeaux);}
  .page-hero--light h1{color:var(--petrol);}
  .page-hero--light h1 em{color:var(--bordeaux);}
  .page-hero--light .lede{color:var(--stein);}

  @media (max-width:960px){
    .page-hero{min-height:420px;padding:72px 0 56px;}
    .page-hero h1{font-size:clamp(34px, 7vw, 56px);}
    .page-hero .lede{font-size:17px;}
    .page-hero--light{padding:72px 0 48px;}
  }
</style>
