---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/fraunces/400.css";
import "@fontsource/fraunces/500.css";
import "@fontsource/fraunces/400-italic.css";
import "@fontsource/fraunces/500-italic.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "CMS-Playground · UNESCO-Schule Essen",
  description = "Decap-CMS Block-Editor Testbed im CD der UNESCO-Schule Essen.",
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="theme-color" content="#0E4D4F">
  <style is:global>
    :root{
      color-scheme: light;
      --petrol:       #0E4D4F;
      --petrol-dark:  #0A3638;
      --bordeaux:     #6E2639;
      --sage:         #7FB069;
      --gold:         #D4A574;
      --creme:        #F5EFE7;
      --offwhite:     #FAF7F1;
      --stein:        #6A6A68;
      --tinte:        #1A1A1A;
      --hairline:     #E8E0D1;

      --container: 1280px;
      --pad-desk: 32px;
      --pad-mob:  20px;

      --space-section:    96px;
      --space-section-sm: 64px;
      --card-padding:     32px;
      --card-radius:      4px;
      --card-accent-width:3px;
      --hero-min-h:       520px;

      --transition-fast: .2s ease;
      --transition:      .3s ease;

      --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      --serif: "Fraunces", Georgia, "Times New Roman", serif;
    }
    *,*::before,*::after{box-sizing:border-box;}
    html,body{margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{
      font-family:var(--sans);color:var(--tinte);background:var(--offwhite);
      font-size:16px;line-height:1.65;
      -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;
      text-rendering:optimizeLegibility;
    }
    img{max-width:100%;display:block;}
    a{color:var(--petrol);text-decoration:none;}
    :focus{outline:none;}
    :focus-visible{outline:2px solid var(--petrol);outline-offset:2px;border-radius:2px;}

    h1,h2,h3,h4{margin:0;font-weight:500;color:var(--petrol);text-wrap:balance;}
    h1{font-family:var(--serif);font-weight:500;letter-spacing:-0.015em;}
    h2{font-family:var(--serif);font-weight:500;font-size:30px;letter-spacing:-0.01em;line-height:1.15;}
    h3{font-family:var(--sans);font-weight:600;font-size:19px;line-height:1.3;}
    p{margin:0;text-wrap:pretty;}

    .container{max-width:var(--container);margin:0 auto;padding:0 var(--pad-desk);}

    .eyebrow{
      font-family:var(--sans);font-weight:500;font-size:12px;
      letter-spacing:0.12em;text-transform:uppercase;color:var(--bordeaux);
    }

    .btn{
      display:inline-flex;align-items:center;gap:8px;
      font-family:var(--sans);font-weight:500;font-size:15px;
      padding:12px 20px;border-radius:4px;
      text-decoration:none;border:1.5px solid transparent;
      transition:background-color .2s, color .2s, border-color .2s;
      cursor:pointer;
    }
    .btn-primary{background:var(--petrol);color:#fff;}
    .btn-primary:hover{background:var(--petrol-dark);}
    .btn-secondary{background:transparent;color:var(--petrol);border-color:var(--petrol);}
    .btn-secondary:hover{background:var(--creme);}

    /* Simple header */
    .site-header{
      position:sticky;top:0;z-index:1000;
      background:rgba(250,247,241,0.92);
      backdrop-filter:saturate(140%) blur(8px);
      -webkit-backdrop-filter:saturate(140%) blur(8px);
      border-bottom:1px solid var(--hairline);
    }
    .header-inner{
      max-width:var(--container);margin:0 auto;
      padding:18px var(--pad-desk);
      display:flex;align-items:center;justify-content:space-between;
    }
    .logo-text{
      font-family:var(--serif);font-weight:500;font-size:20px;color:var(--petrol);
      letter-spacing:-0.01em;
    }
    .logo-sub{
      font-family:var(--sans);font-size:11px;color:var(--stein);
      letter-spacing:0.16em;text-transform:uppercase;margin-left:10px;
      padding-left:10px;border-left:1px solid var(--hairline);
    }
    .header-note{
      font-family:var(--sans);font-size:12px;color:var(--stein);
      letter-spacing:0.04em;
    }
    .header-note a{color:var(--bordeaux);text-decoration:underline;text-underline-offset:3px;}

    footer.site-footer{
      background:var(--petrol);color:var(--creme);
      padding:56px 0 32px;margin-top:96px;
    }
    footer.site-footer .container{
      display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:20px;
    }
    footer.site-footer p{font-family:var(--sans);font-size:14px;color:rgba(245,239,231,0.85);}
    footer.site-footer a{color:var(--gold);border-bottom:1px solid rgba(212,165,116,0.4);}
    @media (max-width:780px){
      footer.site-footer{padding:40px 0 24px;margin-top:64px;}
    }

    @media (prefers-reduced-motion: reduce){
      *,*::before,*::after{
        animation-duration:.001ms !important;
        transition-duration:.001ms !important;
        scroll-behavior:auto !important;
      }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <div>
        <span class="logo-text">CMS-Playground</span>
        <span class="logo-sub">UNESCO-Schule Essen</span>
      </div>
      <span class="header-note">Testumgebung — <a href={`${base}/admin/`}>Decap-Editor öffnen</a></span>
    </div>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="container">
      <p>CMS-Playground · reines Test-Projekt zum Evaluieren von Decap CMS</p>
      <p>Design-Tokens aus <a href="https://tobiaskammer-de.github.io/unesco-schule-essen-homepage" target="_blank" rel="noopener">unesco-schule-essen.de</a></p>
    </div>
  </footer>

  <!-- Netlify Identity Widget: erkennt Invite/Recovery-Tokens und leitet nach Login zu /admin/ -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script is:inline define:vars={{ base }}>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", (user) => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = base + "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
